# Security configuration for uploads directory
# Block direct access to potentially dangerous file types

# Deny access to all .php files
<FilesMatch "\.(php|phtml|php3|php4|php5|pl|py|jsp|asp|sh|cgi)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Only allow specific safe file extensions
<FilesMatch "!^\.(pdf|doc|docx|xls|xlsx|txt|jpg|jpeg|png|gif|bmp|svg|webp)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Prevent execution of any scripts
Options -ExecCGI
Options -Indexes